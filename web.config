<configuration>
  <system.webServer>
    <handlers>
      <!-- Route all requests to Flask via wfastcgi -->
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="FastCgiModule"
           scriptProcessor="C:\inetpub\wwwroot\QIJC-1\venv\Scripts\python.exe|C:\inetpub\wwwroot\QIJC-1\venv\Lib\site-packages\wfastcgi.py"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>
  </system.webServer>

  <appSettings>
    <!-- Flask app object -->
    <add key="WSGI_HANDLER" value="main.app" />

    <!-- Python path to project folder -->
    <add key="PYTHONPATH" value="C:\inetpub\wwwroot\QIJC-1" />
  </appSettings>
</configuration>
